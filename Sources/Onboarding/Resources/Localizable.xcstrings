    "commitmentHold.hold" : {
      "comment" : "Label on the inner button of the commitment-hold step before the user presses and holds. Short, all-caps, gesture-style.",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "HOLD"
          }
        }
      }
    },
    "commitmentHold.hint" : {
      "comment" : "Hint text below the commitment-hold button, instructing the user to press and hold.",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Press and hold"
          }
        }
      }
    },
    "receipt.headerTitle" : {
      "comment" : "Receipt step — brand name at the top of the receipt. Override with your app's brand in your Onboarding.strings.",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ACME"
          }
        }
      }
    },
    "receipt.headerSubtitle" : {
      "comment" : "Receipt step — subtitle under the brand. %d is the trial day count, supplied by the OnboardingDelegate's subscriptionInfo(). Pass an empty string to hide.",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "PREMIUM · %d DAYS"
          }
        }
      }
    },
    "receipt.itemValue" : {
      "comment" : "Receipt step — value shown on the right of every item line. Universal for free trials.",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "FREE"
          }
        }
      }
    },
    "receipt.total" : {
      "comment" : "Receipt step — total label, shown right before the total value.",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "TOTAL"
          }
        }
      }
    },
    "receipt.totalValue" : {
      "comment" : "Receipt step — total value. Always zero for a free trial.",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "$0.00"
          }
        }
      }
    },
    "receipt.stamp" : {
      "comment" : "Receipt step — accent-bordered stamp at the bottom of the receipt, signalling the trial is on the house.",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "✓ ON THE HOUSE"
          }
        }
      }
    },
    "receipt.disclaimer" : {
      "comment" : "Receipt step — small disclaimer line beneath the CTA. Pass an empty string to hide.",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cancel anytime, in two taps."
          }
        }
      }
    },
    "receipt.answerTitle" : {
      "comment" : "Receipt step — primary CTA button label.",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Start free trial"
          }
        }
      }
    },
    "progressBars.title" : {
      "comment" : "Progress bars step — main heading at the top of the loading screen.",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Personalizing your plan…"
          }
        }
      }
    },
    "progressBars.creditNumber" : {
      "comment" : "Progress bars step — required, big number in the credibility block (e.g. \"92%\").",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "92%"
          }
        }
      }
    },
    "progressBars.creditDescription" : {
      "comment" : "Progress bars step — required, description text in the credibility block, below the big number. Use \\n for line breaks.",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "of users\nshow up tomorrow"
          }
        }
      }
    },
    "progressBars.answerTitle" : {
      "comment" : "Progress bars step — primary CTA button label, appears after all bars complete.",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "See my plan"
          }
        }
      }
    },
    "milestoneTimeline.title" : {
      "comment" : "Milestone timeline step — required, main heading above the timeline.",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We catch you before you forget."
          }
        }
      }
    },
    "milestoneTimeline.subtitle" : {
      "comment" : "Milestone timeline step — optional subtitle below the title. Pass an empty string to hide.",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Each milestone arrives right when your memory is about to slip."
          }
        }
      }
    },
    "milestoneTimeline.floatingLabel" : {
      "comment" : "Milestone timeline step — optional chip text that floats above every marker on the timeline (e.g. the word/concept being tracked through the timeline). Pass an empty string to hide.",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "habit"
          }
        }
      }
    },
    "milestoneTimeline.answerTitle" : {
      "comment" : "Milestone timeline step — primary CTA button label.",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tailor it for me"
          }
        }
      }
    },
