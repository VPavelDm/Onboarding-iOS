# Shared fastlane lanes for VPavelDm iOS apps.
#
# Import this file from a project's own Fastfile:
#
#   import "#{ENV['HOME']}/Developer/Onboarding/onboarding-ios/fastlane-shared/Fastfile"
#
# Or override the path via env var:
#
#   shared = ENV["SHARED_FASTLANE_PATH"] ||
#            "#{ENV['HOME']}/Developer/Onboarding/onboarding-ios/fastlane-shared"
#   import "#{shared}/Fastfile"
#
# Each consuming project's Appfile must define `app_identifier`.

default_platform(:ios)

API_KEY_PATH = ENV["ASC_API_KEY_PATH"] || "#{ENV['HOME']}/.fastlane/key.json"

def shared_xcodeproj_path
  candidates = Dir.glob("../*.xcodeproj")
  UI.user_error!("No .xcodeproj found in parent of fastlane dir") if candidates.empty?
  UI.user_error!("Multiple .xcodeproj found: #{candidates.join(', ')}. Pass `xcodeproj:` explicitly.") if candidates.size > 1
  File.expand_path(candidates.first)
end

platform :ios do
  desc "Push metadata-only update to App Store Connect (no binary, no screenshots)"
  lane :push_metadata do
    deliver(
      api_key_path: API_KEY_PATH,
      force: true,
      skip_binary_upload: true,
      skip_screenshots: true,
      skip_app_version_update: true,
      precheck_include_in_app_purchases: false
    )
  end

  desc "Create release/v<version> branch and v<version> tag, push them (triggering Xcode Cloud to build), wait for the new build to finish processing on ASC, submit it for review, then bump main for the next cycle. Re-running from an existing release/v<version> branch cancels the pending review submission, pushes new fix commits (triggering a new Xcode Cloud build), waits, and resubmits — without re-creating the branch or bumping the version."
  desc ""
  desc "Optional:"
  desc "  xcodeproj  Path to .xcodeproj (default: auto-detected in parent dir)"
  desc "  target     Xcode target name (default: derived from xcodeproj basename)"
  lane :submit_release do |options|
    ensure_git_status_clean

    xcodeproj = options[:xcodeproj] || shared_xcodeproj_path
    target = options[:target] || File.basename(xcodeproj, ".xcodeproj")

    release_version = get_version_number(xcodeproj: xcodeproj, target: target)
    release_tag = "v#{release_version}"
    release_branch = "release/#{release_tag}"

    current_branch = sh("git", "rev-parse", "--abbrev-ref", "HEAD").strip
    resubmit = (current_branch == release_branch)

    bundle_id = CredentialsManager::AppfileConfig.try_fetch_value(:app_identifier)
    UI.user_error!("Could not read app_identifier from Appfile") if bundle_id.nil? || bundle_id.empty?

    require "spaceship"
    Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.from_json_file(API_KEY_PATH)

    app = Spaceship::ConnectAPI::App.find(bundle_id)
    UI.user_error!("App #{bundle_id} not found on App Store Connect") unless app

    if resubmit
      UI.message("Re-submission detected (on #{release_branch}). Looking for an existing review submission to cancel…")
      submissions = Spaceship::ConnectAPI::ReviewSubmission.all(
        filter: { "app" => app.id, "platform" => "IOS" }
      )
      cancellable_states = %w[READY_FOR_REVIEW WAITING_FOR_REVIEW IN_REVIEW UNRESOLVED_ISSUES]
      pending = submissions.find { |s| cancellable_states.include?(s.state) }
      if pending
        UI.message("Cancelling review submission #{pending.id} (state=#{pending.state})…")
        pending.cancel_submission
        UI.success("Existing submission cancelled.")
      else
        UI.message("No in-progress review submission found.")
      end
    end

    # Snapshot the current newest build before triggering Xcode Cloud, so the wait
    # loop can tell the new build apart from any pre-existing ones for this version.
    existing = app.get_builds(
      filter: {
        "preReleaseVersion.version" => release_version,
        "preReleaseVersion.platform" => "IOS"
      },
      sort: "-uploadedDate",
      limit: 1
    )
    baseline_build_id = existing.first&.id

    add_git_tag(tag: release_tag, force: true)
    sh("git", "branch", "-f", release_branch) unless resubmit

    # Push branch + tag — this is what triggers Xcode Cloud to build.
    # Plain branch push (no --force) so we fail loudly if the remote already
    # has commits we don't, instead of clobbering someone else's work.
    sh("git", "push", "origin", release_branch)
    sh("git", "push", "--force", "origin", release_tag)

    if resubmit
      # main has already moved on to the next minor — without a PR, fix commits
      # on the release branch would only ship in the patch, never reaching main.
      begin
        existing_pr = sh(
          "gh", "pr", "list",
          "--base", "main",
          "--head", release_branch,
          "--state", "open",
          "--json", "number",
          "--jq", "length"
        ).strip

        if existing_pr == "0"
          sh(
            "gh", "pr", "create",
            "--base", "main",
            "--head", release_branch,
            "--title", "Backport #{release_tag} fixes to main",
            "--body", "Auto-opened by `submit_release`. Merge or cherry-pick these commits into `main` so they're not lost in the next release."
          )
        else
          UI.message("Backport PR from #{release_branch} to main already open — skipping create.")
        end
      rescue => e
        UI.error("Could not open backport PR (#{e.message}). Open it manually: gh pr create --base main --head #{release_branch}")
      end
    else
      # Bump main now (while XC is building) so a failed wait/deliver still leaves
      # main moved on and release/v#{release_version} as the recovery point.
      parts = release_version.split(".").map(&:to_i)
      parts[1] += 1
      next_version = parts.join(".")

      pbxproj_path = "#{xcodeproj}/project.pbxproj"
      sh(
        "sed",
        "-i", "",
        "-e", "s/MARKETING_VERSION = #{release_version};/MARKETING_VERSION = #{next_version};/g",
        pbxproj_path
      )

      git_commit(
        path: "#{File.basename(xcodeproj)}/project.pbxproj",
        message: "Bump marketing version to #{next_version}"
      )

      push_to_git_remote
    end

    # Xcode Cloud builds for this project consistently take 10+ minutes; skip
    # pointless polling during that window.
    UI.message("Sleeping 10 min before polling ASC — Xcode Cloud builds never finish sooner than that.")
    sleep(10 * 60)

    UI.message("Waiting for Xcode Cloud to upload a new build of v#{release_version} and ASC to finish processing it…")
    loop do
      builds = app.get_builds(
        filter: {
          "preReleaseVersion.version" => release_version,
          "preReleaseVersion.platform" => "IOS"
        },
        sort: "-uploadedDate",
        limit: 1,
        includes: "preReleaseVersion"
      )
      latest = builds.first
      if latest.nil? || latest.id == baseline_build_id
        UI.message("No new build yet — checking again in 30s")
      else
        state = latest.processing_state
        UI.message("Build #{latest.version} state: #{state}")
        break if state == "VALID"
        UI.user_error!("Build #{latest.version} failed processing (state=#{state})") if %w[FAILED INVALID].include?(state)
      end
      sleep(30)
    end
    UI.success("Build is ready — proceeding to submit.")

    deliver(
      api_key_path: API_KEY_PATH,
      force: true,
      skip_binary_upload: true,
      skip_screenshots: true,
      submit_for_review: true,
      automatic_release: true,
      submission_information: {
        add_id_info_uses_idfa: false,
        export_compliance_uses_encryption: false
      },
      precheck_include_in_app_purchases: false
    )
  end

  desc "Update subscription prices per territory using a pricing index (default: PPP)"
  desc ""
  desc "Optional (will be prompted interactively if omitted):"
  desc "  product   App Store product ID"
  desc "  base_usd  USA baseline price as a Number (e.g., 9.99)"
  desc ""
  desc "Optional:"
  desc "  index     Index name in fastlane-shared/pricing/indexes/ (default: ppp)"
  desc "  dry_run   Print proposed changes without applying (default: true)"
  desc "  mode      'tier' (Apple cross-market tier match, default) or 'fx' (PPP-adjusted USD × live FX rate)"
  desc ""
  desc "Examples:"
  desc "  fastlane update_subscription_prices                                  # interactive"
  desc "  fastlane update_subscription_prices product:com.x.prime.monthly base_usd:9.99"
  desc "  fastlane update_subscription_prices product:com.x.prime.monthly base_usd:9.99 dry_run:false"
  desc "  fastlane update_subscription_prices product:com.x.prime.monthly base_usd:9.99 mode:fx"
  lane :update_subscription_prices do |options|
    require_relative "pricing/price_updater"

    bundle_id = CredentialsManager::AppfileConfig.try_fetch_value(:app_identifier)
    UI.user_error!("Could not read app_identifier from Appfile") if bundle_id.nil? || bundle_id.empty?

    product = options[:product]
    if product.nil? || product.to_s.empty?
      product = AppStorePricing.prompt_for_product(
        api_key_path: API_KEY_PATH,
        app_bundle_id: bundle_id
      )
    end

    if UI.interactive? && UI.confirm("Update display names for #{product}?")
      AppStorePricing.update_display_name(
        api_key_path: API_KEY_PATH,
        app_bundle_id: bundle_id,
        product_id: product
      )
    end

    base_usd_raw = options[:base_usd]
    if base_usd_raw.nil? || base_usd_raw.to_s.empty?
      UI.user_error!("Non-interactive mode: re-run with base_usd:<price>") unless UI.interactive?
      base_usd_raw = UI.input("Enter USA baseline price for #{product} (empty to skip pricing):")
    end

    if base_usd_raw.nil? || base_usd_raw.to_s.strip.empty?
      UI.message("Skipping price update.")
    else
      base_usd = base_usd_raw.to_f
      UI.user_error!("base_usd must be > 0 (got #{base_usd_raw})") unless base_usd > 0

      index = options[:index] || "ppp"
      dry_run = options[:dry_run].to_s.downcase != "false"
      mode = (options[:mode] || "tier").to_s.downcase
      UI.user_error!("mode must be 'tier' or 'fx' (got #{mode})") unless %w[tier fx].include?(mode)

      AppStorePricing.update(
        api_key_path: API_KEY_PATH,
        app_bundle_id: bundle_id,
        product_id: product,
        base_usd: base_usd,
        index: index,
        dry_run: dry_run,
        mode: mode
      )
    end
  end
end
